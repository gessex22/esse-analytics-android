<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- NO hace falta READ_MEDIA_VIDEO: tanto el Share Sheet como
         OpenMultipleDocuments (SAF) entregan un Uri con permiso de lectura
         de ese archivo puntual sin pedir un permiso de storage aparte. -->

    <application
        android:name=".EsseAnalyticsApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.EsseAnalytics"
        android:supportsRtl="true">

        <!-- Desactiva el auto-init default de WorkManager (vía androidx
             startup) : EsseAnalyticsApp ya provee su propia Configuration
             con HiltWorkerFactory (Configuration.Provider), y tener los dos
             a la vez tira un IllegalStateException al arrancar. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup.InitializationProvider"
                tools:node="remove" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.EsseAnalytics">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link de vuelta del OAuth de YouTube/Instagram/TikTok — ver
                 Parte A del plan (backend/src/controllers/*-upload.controller.ts,
                 popupResult con client=android). autoVerify queda en false: no
                 hay un dominio propio sirviendo un assetlinks.json todavía, así
                 que por ahora es un deep link común, no un App Link verificado. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="essenalytics" android:host="oauth-callback" />
            </intent-filter>

            <!-- Share Sheet: "Compartir → EsseAnalytics" desde Galería/Archivos
                 — camino principal de ingesta (ver plan, sección "Ingesta de
                 videos"). MainActivity los recibe en onCreate/onNewIntent. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="video/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="video/*" />
            </intent-filter>
        </activity>

    </application>

</manifest>
